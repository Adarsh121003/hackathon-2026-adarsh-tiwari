# ─── LLM Provider ──────────────────────────────────────────────
# One of: openai | anthropic | groq | ollama
LLM_PROVIDER=openai

# ─── API Keys (fill only the provider you use) ─────────────────
ANTHROPIC_API_KEY=your-anthropic-key-here
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

GROQ_API_KEY=your-groq-key-here
GROQ_MODEL=llama-3.3-70b-versatile

OPENAI_API_KEY=your-openai-key-here
OPENAI_MODEL=gpt-4o-mini

OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ─── Agent Behavior ────────────────────────────────────────────
MAX_AGENT_STEPS=16
CONFIDENCE_THRESHOLD=0.6
MAX_CONCURRENT_TICKETS=5
HIGH_VALUE_REFUND_THRESHOLD=200.0

# ─── Resilience (retries / timeouts) ───────────────────────────
TOOL_TIMEOUT_SECONDS=5.0
MAX_TOOL_RETRIES=2
RETRY_BASE_DELAY_MS=150

# ─── Chaos Injection (demo-calibrated, not production) ─────────
# Real prod failure is ~0.1–1%; these rates exercise the
# fault-tolerance path visibly for judges without dominating outcomes.
MOCK_TIMEOUT_RATE=0.05
MOCK_MALFORMED_RATE=0.03

# ─── HTTP ──────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173

# ─── Frontend ──────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
